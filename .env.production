# 生产环境配置
# 警告：在生产环境中必须设置所有敏感配置

# 应用配置
DEBUG=false
APP_NAME=企业级问数系统
APP_VERSION=1.0.0

# 安全配置（必须设置）
SECRET_KEY=必须设置32位以上随机字符串
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 数据库配置
META_DB_URL=sqlite:///./data/meta.db
# 或使用 PostgreSQL
# META_DB_URL=postgresql://user:password@localhost:5432/enterprise_data_query

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=必须设置强密码
REDIS_DB=0

# 连接池配置
CONNECTION_POOL_MAX_SIZE=20
CONNECTION_POOL_IDLE_TIMEOUT=300

# DeepAgents 配置
DEEPAGENTS_MODEL=gpt-4
DEEPAGENTS_API_KEY=必须设置您的API密钥
DEEPAGENTS_API_BASE=https://api.deepagents.ai/v1

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 查询限制
MAX_QUERY_ROWS=10000
QUERY_TIMEOUT_SECONDS=60
CACHE_EXPIRE_SECONDS=300

# 审计配置
AUDIT_ENABLED=true
AUDIT_LOG_FILE=logs/audit.log

# 安全增强
PASSWORD_MIN_LENGTH=8
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# CORS 配置（生产环境应限制具体域名）
CORS_ALLOW_ORIGINS=["https://yourdomain.com", "https://app.yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# 监控配置
METRICS_ENABLED=true
METRICS_PORT=9090

# 邮件配置（用于通知）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# 备份配置
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点
BACKUP_RETENTION_DAYS=30